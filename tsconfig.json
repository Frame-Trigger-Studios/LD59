{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
//        TODO engine: backport this to the template
        "noEmit": true,
        /* Linting */
        "strict": true
    },
    "include": ["src"],
    "exclude": ["src/assets/**/*.tsx"]
}
